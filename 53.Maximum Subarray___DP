class Solution {
public:
    int f(int i, vector<int>&nums,vector<int>&dp){
        if (i==0){
            return nums[0];
        }
        if(dp[i]!= INT_MIN){
            return dp[i];
        }
            int case1 = nums[i];
            int case2 = f(i-1, nums, dp)+nums[i];
        return dp[i]= max(case1,case2);
}
    int maxSubArray(vector<int>& nums) {
        int n= nums.size();
        vector<int>dp(n,INT_MIN);
        int res=INT_MIN;
        for(int i=0;i<n;i++){
            res=max(res,f(i,nums,dp));
        }
        return res;
    }
};
